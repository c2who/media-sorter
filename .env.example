# Media Sorter Configuration

# Directory where your download client saves completed downloads
DOWNLOAD_DIR=/media/downloads

# Directory for movies
MOVIES_DIR=/media/movies

# Directory for series (TV shows)
SERIES_DIR=/media/series

# Path to series name mapping file (JSON)
SERIES_MAP_FILE=/app/series_map.json

# Path to passwords file (one per line)
PASSWORDS_FILE=/app/passwords.txt

# Minimum file age in seconds before processing (prevents processing incomplete downloads)
MIN_AGE_SECONDS=300

# Webhook port for triggering processing via HTTP
WEBHOOK_PORT=8765

# Polling interval in seconds
POLL_INTERVAL=300

# Fuzzy matching threshold for series folder names (0.0 - 1.0)
FUZZY_THRESHOLD=0.6

# Number of threads for unrar extraction
UNRAR_THREADS=8

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
